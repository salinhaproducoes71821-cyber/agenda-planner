# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Banco de dados ───────────────────────────────────────────────────────────
# Escolha 'mongo' ou 'mysql'
DB_TYPE=mongo

# MongoDB (ativo quando DB_TYPE=mongo)
MONGO_URI=mongodb://localhost:27017/agenda

# MySQL (ativo quando DB_TYPE=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=senha_aqui
MYSQL_DATABASE=agenda

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_LONGA_E_ALEATORIA
JWT_REFRESH_SECRET=TROQUE_POR_OUTRA_CHAVE_LONGA_E_ALEATORIA
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Separe múltiplas origens com vírgula
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000
