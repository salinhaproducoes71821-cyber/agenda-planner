# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Banco de dados ───────────────────────────────────────────────────────────
# Escolha 'mongo' ou 'mysql'
DB_TYPE=mongo

# MongoDB (ativo quando DB_TYPE=mongo)
MONGO_URI=mongodb://localhost:27017/agenda

# MySQL (ativo quando DB_TYPE=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=senha_aqui
MYSQL_DATABASE=agenda

# ─── Supabase (autenticação) ─────────────────────────────────────────────────
# O backend valida o access token do Supabase. Há dois formatos de assinatura;
# configure conforme o seu projeto (pode definir ambos sem problema):
#
#   • HS256 (legacy JWT Secret, simétrico):
#     Copie de: Supabase → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=COLE_AQUI_O_JWT_SECRET_DO_SUPABASE
#
#   • RS256/ES256 (signing keys assimétricas, validadas via JWKS):
#     Basta a URL do projeto (Settings → API → Project URL). O backend escolhe
#     automaticamente o método pelo header do token.
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Separe múltiplas origens com vírgula
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000
