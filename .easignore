# ─── EAS Build ignore ────────────────────────────────────────────────────────
# Mesma estrutura do .gitignore + arquivos que pertencem só ao backend / repo.
# Reduz tempo de upload e tamanho do contexto enviado para o EAS.

# Standard ignores
node_modules/
.expo/
dist/
web-build/
.metro-health-check*
*.log
.DS_Store
Thumbs.db

# Env (segredos)
.env
.env.example
.env.local
.env.production

# Backend (não é parte do bundle mobile)
api.js
api-service.js.bak
database.js
public/

# Docs e ferramentas internas
docs/
COMO_RODAR.txt
LICENSE
prototipo
README.md
.superpowers/
.claude/

# Backups / arquivos temporários
*.orig.*
*.bak
